# Cosmic CMS credentials — required for the app to start.
# Get these from your Cosmic dashboard: https://app.cosmicjs.com → Bucket Settings → API Access.
COSMIC_BUCKET_SLUG=your-bucket-slug
COSMIC_READ_KEY=your-read-key

# Optional — only needed if you wire up the Cosmic webhook for on-demand
# cache invalidation (POST to /api/revalidate?secret=...).
COSMIC_WEBHOOK_SECRET=

# Optional overrides — defaults work for the standard Cosmic schema.
# COSMIC_TYPE_ALBUM_RATE=albumrates
# COSMIC_TYPE_ALBUM_REVIEW=albumreview
